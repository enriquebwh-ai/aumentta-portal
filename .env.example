# ============================================
# AUMENTTA PORTAL - CONFIGURACIÓN
# ============================================
# Copia este archivo a .env.local y rellena los valores

# 1. SUPABASE (Base de datos PostgreSQL)
# ============================================
# 1. Ve a https://supabase.com
# 2. Crea cuenta → New Project → "aumentta-portal"
# 3. Espera a que termine de crear el proyecto
# 4. Ve a Settings → API
# 5. Copia "Project URL" y "anon public" key

NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGcOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGcOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# 2. OLLAMA (IA local - GRATIS)
# ============================================
# 1. Descarga de https://ollama.com
# 2. Instala y abre Ollama
# 3. Ejecuta en terminal: ollama pull llama3.2
# 4. La URL por defecto ya está configurada

OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL="llama3.2"

# 3. AUTH (NextAuth)
# ============================================
NEXTAUTH_SECRET="cambia-esta-clave-por-una-random-larga"
NEXTAUTH_URL="http://localhost:3000"
